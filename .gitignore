# WoW SavedVariables
SavedVariables/

# OS junk
.DS_Store
Thumbs.db
Desktop.ini

# Editor / IDE files
*.swp
*.swo
*~
.vscode/
.idea/
.luarc.json

# Zip builds
*.zip

# Claude Code (local dev only)
CLAUDE.md
.claude/
.mcp.json
docs/superpowers/
.superpowers/

# Reference material (contents ignored, folder kept via .gitkeep)
_Reference/*
!_Reference/.gitkeep

# Automation (local agent scripts, MCP server, logs)
_Automation/

# WoW CDN cache (TPR client data)
cache/

# GitNexus indexer artifacts (local code-knowledge graph)
# The directory is local-only EXCEPT for wow-config.json, which is shared so
# contributors can rebuild the graph by running `gitnexus analyze` themselves.
# Note: pattern is `.gitnexus/*` (not `.gitnexus/`) so the ! exception works —
# git ignores recursive contents but the directory itself stays traversable.
.gitnexus/*
!.gitnexus/wow-config.json
